{
  "name": "android-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for controlling Android emulators via ADB",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "android-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "android",
    "adb",
    "emulator",
    "claude",
    "testing",
    "model-context-protocol",
    "ui-testing",
    "screenshot",
    "automation",
    "device",
    "appium-alternative"
  ],
  "author": "Martin Geidobler",
  "license": "MIT",
  "homepage": "https://github.com/anthropics/android-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anthropics/android-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/anthropics/android-mcp-server/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1"
  }
}
