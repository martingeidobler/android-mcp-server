{
  "name": "android-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for controlling Android emulators via ADB",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "android-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "android",
    "adb",
    "emulator",
    "claude",
    "testing",
    "model-context-protocol"
  ],
  "author": "Martin Geidobler",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/martingeidobler/android-mcp-server"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
